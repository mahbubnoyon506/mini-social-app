{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_ROUTER_DISABLE_RN_NAVIGATION_CHECK": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_ROUTER_DISABLE_RN_NAVIGATION_CHECK": "1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
